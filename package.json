{
  "name": "kashmir-hotel-booking",
  "version": "1.0.0",
  "description": "Kashmir Travel & Hotel Booking Platform",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node server/seed.js",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
